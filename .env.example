# =============================================================================
# .env.example — copy to .env and fill in. Never commit .env.
#
# m6.config.settings.M6Settings is the single source of truth for what these
# variables mean — see src/m6/config/settings.py.
# =============================================================================

# ---- service ----
M6_ENV=dev                              # dev | test | prod
M6_HOST=0.0.0.0
M6_PORT=8080
M6_LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
M6_LOG_FORMAT=json                      # json | console

# ---- storage ----
M6_DB_PATH=./data/audit.sqlite
M6_FAISS_PATH=./data/index.faiss
M6_SCRATCHPAD_TTL_SECONDS=3600

# ---- compressor defaults ----
M6_DEFAULT_COMPRESSOR=icae              # icae | llmlingua2 | filter | none
M6_DEFAULT_RATIO=4
M6_DEFAULT_TAG_HEAD=false

# ---- inference backend defaults ----
# Every default headline experiment runs LOCALLY. No API key is required to
# reproduce any chapter-headline figure.
M6_INFERENCE_BACKEND=mlx                # mlx | ollama | llamacpp | openai | anthropic
M6_DEFAULT_MODEL=llama-3.1-8b-instruct

# ---- external APIs (OPTIONAL — only for opt-in cost-comparison arms) ----
# Default configs do NOT require these. They are used only by the opt-in
# variants:
#   configs/experiments/baselines-openai.yaml (NarrativeQA/HotpotQA via
#                                              gpt-4o-mini, ~EUR 1)
# Leave both blank for a fully local run.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic powers the optional C3 cost-comparison arm (Claude Haiku 4.5) and
# the 10% Claude Sonnet 4.6 cross-check on the judge. Leave blank for local-only.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_CROSSCHECK_MODEL=claude-sonnet-4-6

# ---- HuggingFace (model downloads) ----
HF_TOKEN=
HF_HOME=./data/hf-cache

# ---- experiment defaults ----
M6_DEFAULT_SEEDS=0,1,2,3,4              # 5 seeds per condition (§5.3)
M6_RESULTS_DIR=./results

# ---- observability ----
OTEL_SERVICE_NAME=m6-memory-bus
OTEL_EXPORTER_OTLP_ENDPOINT=            # leave blank to disable tracing
